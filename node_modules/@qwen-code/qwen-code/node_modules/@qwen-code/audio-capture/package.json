{
  "name": "@qwen-code/audio-capture",
  "version": "0.19.3",
  "description": "Native microphone capture backend for Qwen Code voice input",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
